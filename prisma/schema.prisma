// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js" 
  output = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GroupRole {
  ADMIN 
  STUDENT
}

enum Modality {
  PRESENTIAL
  ONLINE
  HYBRID
}


model Users {
  id       String @id @default(uuid())
  email    String @unique
  password String
  name     String?
  course   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  passwordResetCode    String?   // criado p/ o reset de senha
  passwordResetExpires DateTime? // criado p/ o reset de senha

  groupMembers Group_Members[]
  posts        Post[]
  materials    Material[]

  @@map("users")
}


model Student_Group {
  id                String             @id @default(uuid())
  theme             String
  university_course String?
  description       String?
  modality          Modality @default(ONLINE)
  joinCode          String   @unique
  password          String?
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt
  deleted_at        DateTime?
  
  members           Group_Members[]
  events            Event[]
  posts             Post[]
  materials         Material[]

  @@map("student_groups")
}


model Group_Members {
  user_id   String
  group_id  String
  role GroupRole @default(STUDENT)
  joined_at DateTime @default(now())

  user      Users         @relation(fields: [user_id], references: [id])
  group     Student_Group @relation(fields: [group_id], references: [id])

  @@id([user_id, group_id]) // Chave composta

  @@map("group_members")
}


model Event {
  id                  String           @id @default(uuid())
  studentGroupId    String
  title               String
  date_time_event     DateTime
  local_or_link_event String
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt
  deleted_at          DateTime?

  group               Student_Group @relation(fields: [studentGroupId], references: [id])

  @@map("events")
}


model Post {
  id      String           @id @default(uuid())
  authorId String @map("author_id")
  author   Users  @relation(fields: [authorId], references: [id])
  studentGroupId String
  content          String
  post_date        DateTime      @default(now())
  updated_at       DateTime      @updatedAt
  deleted_at       DateTime?

  group            Student_Group @relation(fields: [studentGroupId], references: [id])

  @@map("posts")
}


model Material {
  id               String  @id @default(uuid())
  uploadedById String @map("uploaded_by_id")
  uploadedBy   Users  @relation(fields: [uploadedById], references: [id])
  studentGroupId   String  @map("student_group_id")
  title            String
  external_url     String
  created_at       DateTime      @default(now())
  updated_at        DateTime      @updatedAt
  deleted_at       DateTime?

  group Student_Group @relation(fields: [studentGroupId], references: [id])

  @@map("materials")
}
